<?xml version="1.0" encoding="UTF-8"?>
<settings xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 http://maven.apache.org/xsd/settings-1.2.0.xsd" xmlns="http://maven.apache.org/SETTINGS/1.2.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <!-- Do not commit real credentials. For local builds, fill in or use ~/.m2/settings.xml. CI/EC2 uses Secrets Manager. -->
  <!-- Resolve + deploy use the same JFrog URL (libs-release-local). -->
  <servers>
    <server>
      <username>REPLACE_JFROG_USERNAME</username>
      <password>REPLACE_JFROG_PASSWORD</password>
      <id>central</id>
    </server>
    <server>
      <username>REPLACE_JFROG_USERNAME</username>
      <password>REPLACE_JFROG_PASSWORD</password>
      <id>snapshots</id>
    </server>
  </servers>
  <profiles>
    <profile>
      <repositories>
        <repository>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
          <id>central</id>
          <name>libs-release-local</name>
          <url>https://trial8hq0mq.jfrog.io/artifactory/libs-release-local</url>
        </repository>
        <repository>
          <snapshots />
          <id>snapshots</id>
          <name>libs-release-local</name>
          <url>https://trial8hq0mq.jfrog.io/artifactory/libs-release-local</url>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
          <id>central</id>
          <name>libs-release-local</name>
          <url>https://trial8hq0mq.jfrog.io/artifactory/libs-release-local</url>
        </pluginRepository>
        <pluginRepository>
          <snapshots />
          <id>snapshots</id>
          <name>libs-release-local</name>
          <url>https://trial8hq0mq.jfrog.io/artifactory/libs-release-local</url>
        </pluginRepository>
      </pluginRepositories>
      <id>artifactory</id>
    </profile>
  </profiles>
  <activeProfiles>
    <activeProfile>artifactory</activeProfile>
  </activeProfiles>
</settings>
